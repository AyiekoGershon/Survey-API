      "name": "GET / - Root",
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status is 200', () => pm.response.to.have.status(200))",
              "",
              "pm.test('Response has message field', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('message');",
              "})",
              "",
              "pm.test('Message is Sky Survey API', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json.message).to.eql('Sky Survey API');",
              "})",
              "",
              "pm.test('Docs link is present', () => {",
              "    const json = pm.response.json();",
              "    pm.expect(json).to.have.property('docs');",
              "})"
            ]
          }
        }
      ],
